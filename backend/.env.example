# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./autotrade.db

# 飞书通知配置（可选）
# 在飞书群创建自定义机器人获取 Webhook URL
FEISHU_WEBHOOK_URL=

# 模拟交易初始资金（USDT）
SIMULATED_INITIAL_BALANCE=100000

# HTTP 代理配置（用于访问 Binance API）
# 格式: http://127.0.0.1:7890 或 https://user:pass@proxy:8080
HTTPS_PROXY=

# ===============================
# 日志配置
# ===============================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志格式: text 或 json
LOG_FORMAT=text

# 单个日志文件最大大小（MB）
LOG_MAX_BYTES=10

# 日志文件保留数量
LOG_BACKUP_COUNT=10

# 是否输出到控制台: true 或 false
LOG_CONSOLE=true
